{
  "@context": {
    "@version": 1.1,
    "@vocab": "https://schema.org/",
    "microsoft": "https://graph.microsoft.com/v1.0/",
    "msgraph": "https://learn.microsoft.com/en-us/graph/api/resources/",
    "planner": "https://graph.microsoft.com/v1.0/planner/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "dcterms": "http://purl.org/dc/terms/",

    "PlannerTask": {
      "@id": "msgraph:plannertask",
      "@context": {
        "id": {
          "@id": "msgraph:plannertask#id",
          "@type": "xsd:string"
        },
        "title": {
          "@id": "schema:name",
          "@type": "xsd:string"
        },
        "description": {
          "@id": "schema:description",
          "@type": "xsd:string"
        },
        "planId": {
          "@id": "msgraph:plannertask#planId",
          "@type": "xsd:string"
        },
        "bucketId": {
          "@id": "msgraph:plannertask#bucketId",
          "@type": "xsd:string"
        },
        "assignments": {
          "@id": "msgraph:plannerassignments",
          "@type": "@id"
        },
        "appliedCategories": {
          "@id": "msgraph:plannerappliedcategories",
          "@type": "@id"
        },
        "priority": {
          "@id": "msgraph:plannertask#priority",
          "@type": "xsd:integer"
        },
        "percentComplete": {
          "@id": "schema:percentComplete",
          "@type": "xsd:integer"
        },
        "startDateTime": {
          "@id": "schema:startDate",
          "@type": "xsd:dateTime"
        },
        "dueDateTime": {
          "@id": "schema:endDate",
          "@type": "xsd:dateTime"
        },
        "completedDateTime": {
          "@id": "msgraph:plannertask#completedDateTime",
          "@type": "xsd:dateTime"
        },
        "completedBy": {
          "@id": "msgraph:plannertask#completedBy",
          "@type": "@id"
        },
        "createdDateTime": {
          "@id": "dcterms:created",
          "@type": "xsd:dateTime"
        },
        "createdBy": {
          "@id": "dcterms:creator",
          "@type": "@id"
        },
        "hasDescription": {
          "@id": "msgraph:plannertask#hasDescription",
          "@type": "xsd:boolean"
        },
        "conversationThreadId": {
          "@id": "msgraph:plannertask#conversationThreadId",
          "@type": "xsd:string"
        },
        "orderHint": {
          "@id": "msgraph:plannertask#orderHint",
          "@type": "xsd:string"
        },
        "assigneePriority": {
          "@id": "msgraph:plannertask#assigneePriority",
          "@type": "xsd:string"
        },
        "previewType": {
          "@id": "msgraph:plannertask#previewType",
          "@type": "xsd:string"
        },
        "activeChecklistItemCount": {
          "@id": "msgraph:plannertask#activeChecklistItemCount",
          "@type": "xsd:integer"
        },
        "checklistItemCount": {
          "@id": "msgraph:plannertask#checklistItemCount",
          "@type": "xsd:integer"
        },
        "referenceCount": {
          "@id": "msgraph:plannertask#referenceCount",
          "@type": "xsd:integer"
        }
      }
    },

    "PlannerPlan": {
      "@id": "msgraph:plannerplan",
      "@context": {
        "id": {
          "@id": "msgraph:plannerplan#id",
          "@type": "xsd:string"
        },
        "title": {
          "@id": "schema:name",
          "@type": "xsd:string"
        },
        "container": {
          "@id": "msgraph:plannerplancontainer",
          "@type": "@id"
        },
        "owner": {
          "@id": "msgraph:plannerplan#owner",
          "@type": "xsd:string"
        },
        "createdBy": {
          "@id": "dcterms:creator",
          "@type": "@id"
        },
        "createdDateTime": {
          "@id": "dcterms:created",
          "@type": "xsd:dateTime"
        }
      }
    },

    "PlannerBucket": {
      "@id": "msgraph:plannerbucket",
      "@context": {
        "id": {
          "@id": "msgraph:plannerbucket#id",
          "@type": "xsd:string"
        },
        "name": {
          "@id": "schema:name",
          "@type": "xsd:string"
        },
        "planId": {
          "@id": "msgraph:plannerbucket#planId",
          "@type": "xsd:string"
        },
        "orderHint": {
          "@id": "msgraph:plannerbucket#orderHint",
          "@type": "xsd:string"
        }
      }
    },

    "PlannerPlanContainer": {
      "@id": "msgraph:plannerplancontainer",
      "@context": {
        "containerId": {
          "@id": "msgraph:plannerplancontainer#containerId",
          "@type": "xsd:string"
        },
        "type": {
          "@id": "msgraph:plannerplancontainer#type",
          "@type": "xsd:string"
        },
        "url": {
          "@id": "msgraph:plannerplancontainer#url",
          "@type": "@id"
        }
      }
    },

    "PlannerTaskDetails": {
      "@id": "msgraph:plannertaskdetails",
      "@context": {
        "id": {
          "@id": "msgraph:plannertaskdetails#id",
          "@type": "xsd:string"
        },
        "description": {
          "@id": "schema:description",
          "@type": "xsd:string"
        },
        "checklist": {
          "@id": "msgraph:plannerchecklistitems",
          "@type": "@id"
        },
        "references": {
          "@id": "msgraph:plannerexternalreferences",
          "@type": "@id"
        },
        "previewType": {
          "@id": "msgraph:plannertaskdetails#previewType",
          "@type": "xsd:string"
        }
      }
    },

    "PlannerPlanDetails": {
      "@id": "msgraph:plannerplandetails",
      "@context": {
        "id": {
          "@id": "msgraph:plannerplandetails#id",
          "@type": "xsd:string"
        },
        "categoryDescriptions": {
          "@id": "msgraph:plannercategorydescriptions",
          "@type": "@id"
        },
        "sharedWith": {
          "@id": "msgraph:planneruserids",
          "@type": "@id"
        }
      }
    },

    "PlannerAssignment": {
      "@id": "msgraph:plannerassignment",
      "@context": {
        "assignedBy": {
          "@id": "msgraph:plannerassignment#assignedBy",
          "@type": "@id"
        },
        "assignedDateTime": {
          "@id": "msgraph:plannerassignment#assignedDateTime",
          "@type": "xsd:dateTime"
        },
        "orderHint": {
          "@id": "msgraph:plannerassignment#orderHint",
          "@type": "xsd:string"
        }
      }
    },

    "PlannerChecklistItem": {
      "@id": "msgraph:plannerchecklistitem",
      "@context": {
        "isChecked": {
          "@id": "msgraph:plannerchecklistitem#isChecked",
          "@type": "xsd:boolean"
        },
        "title": {
          "@id": "schema:name",
          "@type": "xsd:string"
        },
        "orderHint": {
          "@id": "msgraph:plannerchecklistitem#orderHint",
          "@type": "xsd:string"
        },
        "lastModifiedBy": {
          "@id": "dcterms:contributor",
          "@type": "@id"
        },
        "lastModifiedDateTime": {
          "@id": "dcterms:modified",
          "@type": "xsd:dateTime"
        }
      }
    },

    "PlannerExternalReference": {
      "@id": "msgraph:plannerexternalreference",
      "@context": {
        "alias": {
          "@id": "schema:alternateName",
          "@type": "xsd:string"
        },
        "type": {
          "@id": "msgraph:plannerexternalreference#type",
          "@type": "xsd:string"
        },
        "previewPriority": {
          "@id": "msgraph:plannerexternalreference#previewPriority",
          "@type": "xsd:string"
        },
        "lastModifiedBy": {
          "@id": "dcterms:contributor",
          "@type": "@id"
        },
        "lastModifiedDateTime": {
          "@id": "dcterms:modified",
          "@type": "xsd:dateTime"
        }
      }
    },

    "IdentitySet": {
      "@id": "msgraph:identityset",
      "@context": {
        "application": {
          "@id": "msgraph:identityset#application",
          "@type": "@id"
        },
        "device": {
          "@id": "msgraph:identityset#device",
          "@type": "@id"
        },
        "user": {
          "@id": "msgraph:identityset#user",
          "@type": "@id"
        }
      }
    },

    "Identity": {
      "@id": "msgraph:identity",
      "@context": {
        "displayName": {
          "@id": "schema:name",
          "@type": "xsd:string"
        },
        "id": {
          "@id": "msgraph:identity#id",
          "@type": "xsd:string"
        }
      }
    }
  }
}
